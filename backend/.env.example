# ─── SERVER ────────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=production
FRONTEND_URL=https://www.vendoorx.ng
APP_URL=https://www.vendoorx.ng
ALLOWED_ORIGINS=https://www.vendoorx.ng,https://vendoorx.ng

# ─── SUPABASE ──────────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# ─── INTERNAL AUTH ─────────────────────────────────────────────────────────────
INTERNAL_API_KEY=your-random-secret-string

# ─── PAYSTACK ──────────────────────────────────────────────────────────────────
PAYSTACK_SECRET_KEY=sk_live_your-paystack-secret-key
PAYSTACK_WEBHOOK_SECRET=your-paystack-webhook-secret

# ─── CACHE (UPSTASH REDIS) ─────────────────────────────────────────────────────
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# ─── EMAIL (RESEND) ────────────────────────────────────────────────────────────
RESEND_API_KEY=re_your-resend-api-key

# ─── FACE++ VERIFICATION ───────────────────────────────────────────────────────
FACEPP_API_KEY=your-facepp-api-key
FACEPP_API_SECRET=your-facepp-api-secret

# ─── WEB PUSH (VAPID) ──────────────────────────────────────────────────────────
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
VAPID_SUBJECT=mailto:support@vendoorx.ng
