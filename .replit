modules = ["nodejs-20", "web", "postgresql-16"]
[agent]
expertMode = true

[nix]
channel = "stable-25_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Backend API"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm run dev"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow]]
name = "Backend API"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd backend && npm run dev"
waitForPort = 3001

[[ports]]
localPort = 3001
externalPort = 3001

[[ports]]
localPort = 5000
externalPort = 80

[userenv]

[userenv.shared]
NEXT_PUBLIC_BACKEND_URL = "https://fa75bd1a-5f2d-4cc8-828f-85270cdb330d-00-3nm0oboepxdxj.picard.replit.dev:3001"
FRONTEND_URL = "https://fa75bd1a-5f2d-4cc8-828f-85270cdb330d-00-3nm0oboepxdxj.picard.replit.dev"
NEXT_PUBLIC_SITE_URL = "https://fa75bd1a-5f2d-4cc8-828f-85270cdb330d-00-3nm0oboepxdxj.picard.replit.dev"

[deployment]
deploymentTarget = "vm"
run = ["bash", "-c", "cd backend && npm run start & npm run start"]
build = ["bash", "-c", "npm install && cd backend && npm install && cd .. && npm run build"]
